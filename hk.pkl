amends "package://github.com/jdx/hk/releases/download/v1.39.0/hk@1.39.0#/Config.pkl"
import "package://github.com/jdx/hk/releases/download/v1.39.0/hk@1.39.0#/Builtins.pkl"

local formatters = new Mapping<String, Step> {
  ["zig_fmt"] {
    glob = List("**/*.zig", "**/*.zon")
    check = "zig fmt --check {{files}}"
    fix = "zig fmt {{files}}"
  }
  ["pkl_format"] = Builtins.pkl_format
  ["mise"] = Builtins.mise
  ["trailing_whitespace"] = (Builtins.trailing_whitespace) {
    types = List("text")
    exclude = List("tests/resources/release/**", "tests/resources/changelog/**")
  }
  ["newlines"] = (Builtins.newlines) {
    types = List("text")
    exclude = List("tests/resources/release/**", "tests/resources/changelog/**")
  }
}

local checkers = new Mapping<String, Step> {
  ["action_validator"] {
    depends = List("yamlfmt")
    glob = List(".github/workflows/*.yml", ".github/workflows/*.yaml")
    check = "action-validator {{files}}"
  }
  ["pkl"] = Builtins.pkl
  ["actionlint"] = (Builtins.actionlint) {
    depends = List("newlines", "trailing_whitespace")
  }
  ["pinact"] = Builtins.pinact
  ["zizmor"] = Builtins.zizmor
}

local linters = new Mapping<String, Step> {
  ["zig_build"] {
    glob = List("**/*.zig", "**/*.zon")
    check = "zig build --summary all"
  }
  ["zig_test"] {
    glob = List("**/*.zig")
    check = "zig build --summary all test"
  }
}

local baseHook = new Hook {
  steps {
    ["formatters"] = new Group {
      steps = formatters
    }
    ["checkers"] = new Group {
      steps = checkers
    }
  }
}

hooks {
  ["pre-commit"] = (baseHook) {
    fix = true
    stash = "git"
  }
  ["fix"] = (baseHook) {
    fix = true
  }
  ["check"] = baseHook
  ["lint"] {
    steps = linters
  }
}
